{
  "manifest_version": 3,
  "name": "ReelSaver Pro",
  "description": "Download Instagram Reels as video or audio with URL and auto-detect modes.",
  "version": "1.0.1",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ReelSaver Pro",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "tabs", "downloads", "storage"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "http://localhost:4000/*",
    "http://127.0.0.1:4000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
